guard.velocity = -12
air.velocity = -2, -4
airguard.velocity = -6, 0
envshake.time = 6
envshake.ampl = -6
envshake.freq = 50
getpower = 0, 0
givepower = 10
fall = ifelse(var(5) > 3, 1, 0)
air.fall = 1
fall.recover = 0
ground.cornerpush.veloff = 0
guard.cornerpush.veloff = 0

[State 3002, displacement]
