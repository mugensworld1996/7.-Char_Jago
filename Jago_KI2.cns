trigger1 = enemynear, ctrl
v = 9
value = 0

[State -2, air reset push]
type = varset
trigger1 = p2bodydist x > 50 && vel y = 0
trigger2 = p2movetype != H || p2stateno = [5100, 5200]
trigger3 = (enemynear, ctrl);safety
v = 11
value = 0

[State -2, keep track of no more hit]
