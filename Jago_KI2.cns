trigger1 = animelem = 1
attr = S, HA
hitflag = MAF
guardflag = MA
priority = 5, hit
hitsound = s14, 0
guardsound = s15, 1
damage = ceil(100 * fvar(0)), 15
sparkxy = -20, -91
sparkno = s7970
guard.sparkno = s7950
