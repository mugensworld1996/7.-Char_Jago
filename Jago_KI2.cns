trigger1 = animelem = 1 && !moveguarded
x = 10.5

[State 3002, friction]
type = velmul
trigger1 = time > 5
x = 0.75

[State 3002, close friction]
type = velmul
trigger1 = p2bodydist x = 0
x = 0.75

[State 3002, dont let pass]
type = velmul
trigger1 = p2bodydist x < -1
x = 0.2

[State 3002 guarded]
type = velset
trigger1 = moveguarded = 1
x = ifelse(enemynear, backedgebodydist = 0, -8.75, -8)

;-- activates --
[State 3002, activate autodouble]
