[State 12600, jump]
type = veladd
trigger1 = animelem = 1
x = -1
y = -5

[State 12600, grav]
type = gravity
trigger1 = pos y < -vel y
trigger1 = pos y < 0

[State 12600, posset]
type = posset
trigger1 = pos y >= 0 && time > 5
y = 0

[State 12600, stop]
type = velset
trigger1 = pos y >= 0 && time > 5
x = 0
y = 0

[State 12600, return]
type = selfstate
trigger1 = animtime = 0
value = 5150

