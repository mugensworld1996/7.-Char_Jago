;---------------------------------------------------------------------------
; Dash forward

[Statedef 100]
type    = S
physics = S
anim = 100
sprpriority = 1
ctrl = 0

;-----------
[State 100, 4]
type = posadd
trigger1 = time = 2
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 10, 21)

[State 100, 5]
type = posadd
trigger1 = time = 3
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 5, 10)

[State 100, 5]
type = posadd
trigger1 = time = 4
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 5, 10)

[State 100, 5]
type = posadd
trigger1 = time = 5
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 7, 13)

[State 100, 5]
type = posadd
trigger1 = time = 6
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 4, 7)

[State 100, 5]
type = posadd
trigger1 = time = 8
x = ifelse((p2bodydist x < 5 && p2bodydist y >= 0), 5, 10)

;-------------

[State 100, 2] ;Prevent run from canceling into walk
type = AssertSpecial
trigger1 = 1
flag = NoWalk

[State 100, 3] ;Prevent from turning
type = AssertSpecial
trigger1 = 1
flag = NoAutoTurn

[State 100, return ctrl]
type = ctrlset
trigger1 = time > 17
value = 1

[State 100, 4]
type = ChangeState
trigger1 = animtime = 0
value = 0
ctrl = 1
