[Statedef -2]

[State -2, proj hit]
type = explod
id = 7902
trigger1 = projhit1020 = 1
trigger2 = projhit1050 = 1
anim = 7902
postype = p2
facing = -1
pos = -25, -100
sprpriority = 6
trans = addalpha
alpha = 256, 224
ignorehitpause = 0
pos = floor(80 + (p2bodydist x * 0.85)), -90

[State -2, hitcount var]
