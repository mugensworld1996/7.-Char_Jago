trigger1 = p2stateno != [5000, 5100]
fv = 0
value = 1

[State -2, times hit]
type = varadd
trigger1 = stateno = 5000 && time = 0
v = 21
value = 1

[State -2, times hit reset]
type = varset
trigger1 = hitover
v = 21
value = 0

[State -2, hitcheck reset]
type = varset
trigger1 = vel y > 0
v = 13
value = 0

[State -2, tech hit reset]
type = varset
trigger1 = command != "holdback"
trigger1 = command != "hold x"
v = 10
value = 0

[State -2, ultimate no music]
type = assertspecial
trigger1 = var(18)
flag = nomusic

[State -2, darken]
