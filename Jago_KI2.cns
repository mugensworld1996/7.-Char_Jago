trigger1 = 1
text = "distance = %d combo time = %d 5 = %d, time after hit = %d, p2height = %d"
params = var(30), var(25), var(5), var(33), var(19)

[State -2, append]
type = appendtoclipboard
trigger1 = 1
text = "\nfront = %d, win = %d"
params = (enemynear, frontedgebodydist), var(59)

