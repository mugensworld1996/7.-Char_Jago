trigger1 = movehit = 1
statetype = s

[State 3002, increment combo count]
type = varadd
trigger1 = movehit = 1
v = 5
value = 1

[State 3002, hitcount]
type = varadd
trigger1 = movehit = 1
v = 20
value = 1

[State 3002, air push]
type = varset
trigger1 = movehit = 1  && p2statetype = a
v = 9
value = 1

[State 3002, return]
type = changestate
trigger1 = animtime = 0
value = 1202

